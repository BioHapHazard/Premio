# Server Configuration
PORT=3001

# Jackett Configuration
# Local Jackett instance URL (default: http://localhost:9117)
JACKETT_URL=http://localhost:9117
# Your Jackett API key (found in the top right of the Jackett web UI)
JACKETT_API_KEY=your_jackett_api_key_here

# Premiumize Configuration
# Your Premiumize API key (found at https://www.premiumize.me/account)
PREMIUMIZE_API_KEY=your_premiumize_api_key_here

# TMDb API Key (Free at https://www.themoviedb.org/settings/api)
# You can use EITHER the v3 API Key OR the v4 Read Access Token (preferred/safer).
# If both are set, the backend will prefer the v4 API Read Access Token.
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_TOKEN=your_tmdb_read_access_token_here

# NZBGeek (Newznab) Usenet Indexer Configuration
NZBGEEK_API_KEY=your_nzbgeek_api_key_here

# =============================================================================
# Security / deployment model (bring-your-own-key)
# =============================================================================
# This app is BYOK: every visitor supplies their OWN keys via the in-app Settings
# (sent as request headers). In production, leave ALLOW_ENV_KEYS unset/false so the
# server NEVER falls back to the keys above — that prevents anonymous visitors from
# spending the owner's Premiumize account/quota/AI credits.
#
# Set ALLOW_ENV_KEYS=true ONLY for local/sandbox dev, to let the server use the
# keys in this file so you can test without entering keys in the UI.
ALLOW_ENV_KEYS=false

# Optionally let the server fund TMDb metadata (posters/ratings) for everyone using
# the TMDB_* keys above. Read-only and rate-limited. Leave false for pure BYOK.
ENABLE_SHARED_TMDB=false

# Comma-separated list of browser origins allowed to call the API cross-origin.
# Same-origin and non-browser (curl/server-side) requests are always allowed.
# Set this to your public site origin in production, e.g. https://your-app.example
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Public base URL of this server, used to build callback URLs (e.g. NZB import).
# Set in production so links don't depend on spoofable x-forwarded-* headers.
# Example: https://your-app.fly.dev
# PUBLIC_BASE_URL=

