{
  "name": "premium-search-backend",
  "version": "1.0.0",
  "description": "Premiumize-aware torrent search backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "install-all": "npm install && cd frontend && npm install",
    "dev-all": "npx concurrently \"npm run dev\" \"cd frontend && npm run dev\""
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-unrar-js": "^2.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
